        "specifyBody": "json",
        "jsonBody": "={\n  \"chat_id\": \"{{ $('Set params').item.json.chatId }}\",\n  \"text\": \"Este bot todavia no esta configurado. Contacta con el administrador.\"\n}",
        "options": {}
      },
      "id": "node-bot-not-configured",
      "name": "Bot no configurado",
