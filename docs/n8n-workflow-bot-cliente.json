      "id": "node-switch",
      "name": "Router intent",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1000, 600]
    },
    {
      "parameters": {
        "jsCode": "const params = $('Set params').item.json;\nconst lookup = $('Lookup Salon').item.json;\nconst salon = lookup.salon;\nconst nombre = salon.nombre;\nconst agente = salon.agente_nombre || 'Asistente';\nconst bienvenida = salon.agente_bienvenida || `Hola ${params.userName}, soy ${agente} del salon ${nombre}. Que quieres hacer?`;\n\nreturn [{\n  json: {\n    chat_id: params.chatId,\n    text: bienvenida,\n    parse_mode: 'HTML',\n    reply_markup: {\n      inline_keyboard: [\n        [{ text: 'Reservar', callback_data: 'menu:reservar' }],\n        [{ text: 'Mis citas', callback_data: 'menu:miscitas' }],\n        [{ text: 'Servicios', callback_data: 'menu:servicios' }, { text: 'Horario', callback_data: 'menu:horario' }]\n      ]\n    }\n  }\n}];"
      },
      "id": "node-build-start",
      "name": "Build /start menu",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 200]
    },
    {
      "parameters": {
        "jsCode": "const params = $('Set params').item.json;\nconst lookup = $('Lookup Salon').item.json;\nconst servicios = lookup.servicios || [];\n\nconst rows = servicios.map(s => ([{\n  text: `${s.nombre} (${s.duracion_min} min, ${s.precio_eur} EUR)`,\n  callback_data: `srv:${s.id}`\n}]));\n\nreturn [{\n  json: {\n    chat_id: params.chatId,\n    text: 'Elige un servicio:',\n    parse_mode: 'HTML',\n    reply_markup: { inline_keyboard: rows }\n  }\n}];"
      },
      "id": "node-build-reservar",
      "name": "Build servicios list",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 350]
    },
    {
      "parameters": {
        "jsCode": "// TODO: Branch C (srv:<id>) - mostrar profesionales\nconst params = $('Set params').item.json;\nconst lookup = $('Lookup Salon').item.json;\nconst servId = params.callbackData.split(':')[1];\nconst profesionales = lookup.profesionales || [];\n\nconst rows = profesionales.map(p => ([{\n  text: p.nombre,\n  callback_data: `prf:${servId}:${p.id}`\n}]));\nrows.push([{ text: 'Cualquiera', callback_data: `prf:${servId}:any` }]);\n\nreturn [{\n  json: {\n    chat_id: params.chatId,\n    text: 'Con que profesional?',\n    parse_mode: 'HTML',\n    reply_markup: { inline_keyboard: rows }\n  }\n}];"
      },
      "id": "node-build-srv",
      "name": "Build profesionales list",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 500]
    },
    {
      "parameters": {
        "jsCode": "// Branch D (prf:<servId>:<profId>) -> selector de fecha (3 dias)\nconst params = $('Set params').item.json;\nconst parts = params.callbackData.split(':');\nconst servId = parts[1];\nconst profId = parts[2];\nconst hoy = new Date();\nconst d = (n) => {\n  const x = new Date(hoy.getTime() + n*86400000);\n  return x.toISOString().slice(0,10);\n};\nconst rows = [\n  [{ text: 'Hoy', callback_data: `fch:${servId}:${profId}:${d(0)}` }],\n  [{ text: 'Manana', callback_data: `fch:${servId}:${profId}:${d(1)}` }],\n  [{ text: 'Pasado', callback_data: `fch:${servId}:${profId}:${d(2)}` }]\n];\nreturn [{ json: { chat_id: params.chatId, text: 'Para que dia?', reply_markup: { inline_keyboard: rows } } }];"
      },
      "id": "node-build-prf",
      "name": "Build fecha selector",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 650]
    },
    {
      "parameters": {
        "jsCode": "// Branch E (fch:<servId>:<profId>:<fecha>) -> llamar a /disponibilidad y mostrar slots\n// TODO: este nodo solo prepara la URL. Anadir un HTTP Request despues que la consuma y otro Code que formatee los slots como botones inline (callback `slot:<servId>:<profId>:<isoUtc>`).\nconst params = $('Set params').item.json;\nconst parts = params.callbackData.split(':');\nconst servId = parts[1];\nconst profId = parts[2];\nconst fecha = parts[3];\nconst slug = params.slug;\nconst profQuery = (profId && profId !== 'any') ? `&profesional_id=${profId}` : '';\nconst url = `https://gestori.es/api/v1/salones/${slug}/disponibilidad?servicio_id=${servId}&fecha=${fecha}${profQuery}`;\nreturn [{ json: { url, servId, profId, fecha, chatId: params.chatId } }];"
      },
      "id": "node-build-fch",
      "name": "Build disponibilidad URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 800]
    },
    {
      "parameters": {
        "jsCode": "// Branch F (slot:<servId>:<profId>:<isoUtc>) -> resumen + boton confirmar\n// TODO: incluir paso de pedir telefono con force_reply si el cliente no tiene telefono guardado.\nconst params = $('Set params').item.json;\nconst parts = params.callbackData.split(':');\nconst servId = parts[1];\nconst profId = parts[2];\nconst iso = parts.slice(3).join(':');\nconst lookup = $('Lookup Salon').item.json;\nconst serv = (lookup.servicios || []).find(s => s.id === servId);\nconst prof = (lookup.profesionales || []).find(p => p.id === profId);\nconst rows = [[{ text: 'Confirmar reserva', callback_data: `book:${servId}:${profId}:${iso}` }], [{ text: 'Cancelar', callback_data: 'menu:reservar' }]];\nreturn [{ json: { chat_id: params.chatId, text: `Resumen:\\n- Servicio: ${serv?.nombre}\\n- Profesional: ${prof?.nombre || 'cualquiera'}\\n- Fecha (UTC): ${iso}\\n\\nConfirmas?`, reply_markup: { inline_keyboard: rows } } }];"
      },
      "id": "node-build-slot",
      "name": "Build resumen reserva",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 950]
    },
    {
      "parameters": {
        "jsCode": "// Branch G (book:<servId>:<profId>:<isoUtc>) -> POST /citas\n// TODO: anadir HTTP Request despues que haga el POST a `url` con header auth y body, luego un Code que formatee la confirmacion antes del sendMessage final.\nconst params = $('Set params').item.json;\nconst parts = params.callbackData.split(':');\nconst servId = parts[1];\nconst profId = parts[2];\nconst iso = parts.slice(3).join(':');\nconst slug = params.slug;\nconst body = {\n  servicio_id: servId,\n  profesional_id: (profId === 'any') ? null : profId,\n  inicio: iso,\n  cliente: { telegram_id: String(params.userId), nombre: params.userName },\n  origen: 'telegram'\n};\nreturn [{ json: { url: `https://gestori.es/api/v1/salones/${slug}/citas`, body, chatId: params.chatId } }];"
      },
      "id": "node-build-book",
      "name": "Build POST cita",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 1100]
    },
    {
      "parameters": {
        "jsCode": "// Branch H (menu:miscitas) -> listar citas del cliente\n// TODO: anadir HTTP Request GET despues + Code que formatee la lista en HTML.\nconst params = $('Set params').item.json;\nconst slug = params.slug;\nconst url = `https://gestori.es/api/v1/salones/${slug}/citas?cliente_telegram_id=${params.userId}`;\nreturn [{ json: { url, chatId: params.chatId } }];"
      },
      "id": "node-build-miscitas",
      "name": "Build mis citas URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 1250]
    },
    {
      "parameters": {
        "jsCode": "// Branch I (menu:servicios)\nconst params = $('Set params').item.json;\nconst lookup = $('Lookup Salon').item.json;\nconst lista = lookup.servicios_lista || (lookup.servicios || []).map(s => `- ${s.nombre} (${s.duracion_min} min, ${s.precio_eur} EUR)`).join('\\n');\nreturn [{ json: { chat_id: params.chatId, text: `<b>Servicios</b>\\n${lista}`, parse_mode: 'HTML' } }];"
      },
      "id": "node-build-servicios",
      "name": "Build servicios info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 1400]
    },
    {
      "parameters": {
        "jsCode": "// Branch J (menu:horario) - TODO: enriquecer con horarios reales del lookup si los expone\nconst params = $('Set params').item.json;\nconst lookup = $('Lookup Salon').item.json;\nconst tz = lookup.salon.timezone || 'Europe/Madrid';\nreturn [{ json: { chat_id: params.chatId, text: `<b>Horario</b>\\nZona horaria: ${tz}\\nConsulta el panel del salon para ver el detalle.`, parse_mode: 'HTML' } }];"
      },
      "id": "node-build-horario",
      "name": "Build horario",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 1550]
    },
    {
      "parameters": {
        "jsCode": "// Branch K (confirmar:<citaId>)\n// TODO: anadir HTTP Request POST a /api/v1/citas/<id>/confirmar y formatear respuesta.\nconst params = $('Set params').item.json;\nconst citaId = params.callbackData.split(':')[1];\nreturn [{ json: { url: `https://gestori.es/api/v1/citas/${citaId}/confirmar`, body: {}, chatId: params.chatId, citaId } }];"
      },
      "id": "node-build-confirmar",
      "name": "Build confirmar URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 1700]
    },
    {
      "parameters": {
        "jsCode": "// Branch L (cancelar:<citaId>)\n// TODO: anadir HTTP Request POST a /api/v1/citas/<id>/cancelar y formatear respuesta.\nconst params = $('Set params').item.json;\nconst citaId = params.callbackData.split(':')[1];\nreturn [{ json: { url: `https://gestori.es/api/v1/citas/${citaId}/cancelar`, body: { motivo: 'Cancelada por el cliente desde Telegram' }, chatId: params.chatId, citaId } }];"
      },
      "id": "node-build-cancelar",
      "name": "Build cancelar URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 1850]
    },
    {
      "parameters": {
        "jsCode": "// Branch M fallback (texto libre)\n// TODO opcional: invocar a Gemini Flash con el system prompt del agente_nombre/tono y servicios_lista para responder en lenguaje natural y ofrecer el menu.\nconst params = $('Set params').item.json;\nreturn [{ json: { chat_id: params.chatId, text: 'No te he entendido. Usa /start para abrir el menu.' } }];"
      },
      "id": "node-build-fallback",
      "name": "Build fallback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 2000]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $('Lookup Salon').item.json.salon.telegram_bot_token }}/sendMessage",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "node-send-message",
      "name": "Telegram sendMessage",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1700, 1000]
    }
  ],
