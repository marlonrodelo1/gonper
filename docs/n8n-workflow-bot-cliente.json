{
  "name": "Gomper - Bot del salon (multi-tenant)",
  "active": false,
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "gomper-bot/:slug",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "node-webhook",
      "name": "Webhook Telegram",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 400],
      "webhookId": "gomper-bot-multi-tenant"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "a1", "name": "slug", "value": "={{ $json.params.slug }}", "type": "string" },
            { "id": "a2", "name": "update", "value": "={{ $json.body }}", "type": "object" },
            { "id": "a3", "name": "chatId", "value": "={{ $json.body.message?.chat?.id ?? $json.body.callback_query?.message?.chat?.id }}", "type": "string" },
            { "id": "a4", "name": "userId", "value": "={{ $json.body.message?.from?.id ?? $json.body.callback_query?.from?.id }}", "type": "string" },
            { "id": "a5", "name": "userName", "value": "={{ $json.body.message?.from?.first_name ?? $json.body.callback_query?.from?.first_name ?? 'cliente' }}", "type": "string" },
            { "id": "a6", "name": "text", "value": "={{ $json.body.message?.text ?? '' }}", "type": "string" },
            { "id": "a7", "name": "callbackData", "value": "={{ $json.body.callback_query?.data ?? '' }}", "type": "string" },
            { "id": "a8", "name": "callbackQueryId", "value": "={{ $json.body.callback_query?.id ?? '' }}", "type": "string" },
            { "id": "a9", "name": "startPayload", "value": "={{ ($json.body.message?.text ?? '').startsWith('/start ') ? ($json.body.message.text.substring(7)) : '' }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "node-set-params",
      "name": "Set params",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [400, 400]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://gestori.es/api/v1/lookup-bot?slug={{ $json.slug }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "response": {
            "response": {
              "fullResponse": false,
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "node-lookup",
      "name": "Lookup Salon",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [600, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_WITH_CREDENTIAL_ID",
          "name": "Header Auth Gomper API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "c-not-found",
              "leftValue": "={{ $json.salon?.id ?? null }}",
              "rightValue": null,
              "operator": { "type": "object", "operation": "empty", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-notfound",
      "name": "Salon existe?",
