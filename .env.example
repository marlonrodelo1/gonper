# Supabase (panel + clientes)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Database (Drizzle, server-side, no NEXT_PUBLIC)
# ⚠️ USA EL POOLER (IPv4, puerto 6543), NO el direct connection.
# El direct host (db.X.supabase.co) sólo es IPv6 y la mayoría de VPS no lo resuelven (ENOTFOUND).
# Sustituye REF, PASSWORD y la región (eu-west-1, us-east-1, etc.) por los de tu proyecto.
DATABASE_URL=postgresql://postgres.[REF]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Service role (server-side only — para n8n y edge functions)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Telegram bots
TELEGRAM_BOT_TOKEN=

# Sentry / PostHog
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# n8n webhook (opcional)
N8N_WEBHOOK_URL=

# Resend (email transaccional). Si no se configura, los emails se loguean a stdout.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Gomper <onboarding@resend.dev>"

# Token interno para auth de /api/v1/* (n8n)
INTERNAL_API_TOKEN=
